{
  "name": "linksaver",
  "version": "1.0.0",
  "description": "Tiny link saver: paste a URL, auto-fetch its title, list, favourite and delete.",
  "main": "server.js",
  "scripts": {
    "start": "node --no-warnings=ExperimentalWarning server.js",
    "dev": "node --watch --no-warnings=ExperimentalWarning server.js",
    "test": "node --no-warnings=ExperimentalWarning node_modules/.bin/jest --runInBand"
  },
  "engines": {
    "node": ">=22.5"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "app.js",
      "db.js",
      "lib/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
